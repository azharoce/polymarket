# ================================================================================
# POLYMARKET AUTOBET BOT - Environment Variables
# ================================================================================

# ================================================================================
# LAYER 1 - WALLET (WAJIB)
# ================================================================================
# Cara dapat PRIVATE_KEY:
#   1. Phantom: Settings → Security → Reveal Secret Recovery Phrase
#   2. Atau di Metamask: Account Details → Export Private Key
#   NOTE: Private key harus pakai format dengan prefix 0x
PRIVATE_KEY=0xb0132101ae7eaa9c156b1de5bedf112eb16073f1b8c461ece331f52548bafbea

# Cara dapat FUNDER_ADDRESS:
#   1. Buka polymarket.com/settings
#   2. Scroll ke section "Funding"
#   3. Copy alamat wallet yang tertera
FUNDER_ADDRESS=0x86cE9823998f6F323151aA613e751156Dc1b9486

# ================================================================================
# LAYER 2 - CLOB API CREDENTIALS (Untuk Real Trading)
# ================================================================================
# Cara dapat POLY_API_KEY, SECRET, PASSPHRASE:
#   1. Buka polymarket.com/settings → API Keys
#   2. Atau gunakan script: python -m bot.generate_creds
#   3. Atau lewat py_clob_client: client.create_or_derive_api_creds()
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# ================================================================================
# LAYER 3 - BLOCKCHAIN RPC (Untuk Polygon)
# ================================================================================
# Cara dapat RPC_URL & WSS_URL:
#   1. Alchemy: https://dashboard.alchemy.com/ (free tier tersedia)
#   2. Infura: https://infura.io/
#   3. QuickNode: https://quicknode.com/
#   4. Atau gunakan Polygon RPC gratis: https://polygon-rpc.com
RPC_URL=https://polygon-rpc.com

# WSS_URL untuk real-time updates (optional - bisa dapat dari Alchemy/Infura)
WSS_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# ================================================================================
# CONTRACT ADDRESSES (Sudah Fixed - Jangan Ubah)
# ================================================================================
USDC_CONTRACT_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
CLOB_HTTP_URL=https://clob.polymarket.com

# ================================================================================
# BOT CONFIGURATION
# ================================================================================
DRY_RUN=true              # true = simulation, false = real trading
SCAN_INTERVAL=60          # dalam detik
MAX_DAILY_LOSS=0.05       # 5% max daily loss
MAX_POSITION_SIZE=0.1     # 10% max position per trade
MAX_CONSECUTIVE_LOSSES=3  # Stop setelah 3x kalah berturut

# ================================================================================
# LEGACY - Relayer API
# ================================================================================
RELAYER_API_KEY=019d2216-8d1b-7ed1-b2a0-76932b1d41a3
RELAYER_API_KEY_ADDRESS=0x86cE9823998f6F323151aA613e751156Dc1b9486
