# Polymarket Trading Bot Environment Variables

# Polygon Network Configuration
POLYGON_RPC_URL=https://polygon-rpc.com

# Wallet Configuration (NEVER commit your actual private key to version control!)
PRIVATE_KEY=019d2216-8d1b-7ed1-b2a0-76932b1d41a3

# Risk Management Parameters (optional - defaults will be used if not set)
MAX_DAILY_LOSS=0.05          # 5% maximum daily loss
MAX_POSITION_SIZE=0.1        # 10% maximum position size per trade
STOP_LOSS_PERCENTAGE=0.02    # 2% stop loss
MAX_CONSECUTIVE_LOSSES=3     # Stop after 3 consecutive losses
DAILY_RESET_HOUR=0           # Reset daily stats at UTC hour 0 (midnight)